# CricRoar Environment Variables
# Copy this file, rename to .env and fill in your keys
# On Vercel: add these in Project Settings > Environment Variables

VITE_CRICKET_API=your_cricketdata_api_key_here
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_KEY=your_supabase_anon_key_here
VITE_RAZORPAY_KEY=your_razorpay_key_id_here
