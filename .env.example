# CricRoar — Environment Variables
# Copy this to .env.local and fill in your actual keys
# All keys go in Vercel → Settings → Environment Variables

# Supabase (free — supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-public-key

# CricketData.org (free tier — cricketdata.org)
VITE_CRICKET_API=your-cricketdata-api-key

# Google Gemini (free — aistudio.google.com)
VITE_GEMINI_KEY=your-gemini-api-key

# Razorpay — use your existing account
VITE_RAZORPAY_KEY=rzp_live_xxxxxxxxxxxx
